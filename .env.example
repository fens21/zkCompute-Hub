# Environment Variables untuk Job Marketplace LitForge Testnet
# Salin file ini menjadi .env dan isi nilainya

# Private key wallet untuk deploy smart contract (Hardhat)
# ⚠️ JANGAN commit private key asli ke git! Gunakan environment variable terpisah.
PRIVATE_KEY=your_private_key_here

# Contract address (frontend Vite, prefix VITE_)
# Default address jika tidak di-set
VITE_CONTRACT_ADDRESS=0x26535Da2049484FFc858c6C4bE47C2095a32975d

# Supabase
# ⚠️ Pastikan Row Level Security (RLS) diaktifkan di Supabase Dashboard:
#   1. Buka Supabase Dashboard → SQL Editor
#   2. Jalankan:
#      ALTER TABLE job_metadata ENABLE ROW LEVEL SECURITY;
#      ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;
#      ALTER TABLE activities ENABLE ROW LEVEL SECURITY;
#   3. Buat policies yang sesuai (contoh: anon can read, authenticated can insert/update)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
